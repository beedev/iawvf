# IAW Decision Framework — Frontend Environment Variables
# Copy this file to `.env` (or `.env.local`) and adjust for your environment.
# Never commit `.env` / `.env.local` or any file containing real secrets.

# VDF API base URL (no trailing slash). The Node API runs on http://localhost:4000.
# CORS on the API allows http://localhost:5173 (the Vite dev server origin).
VITE_API_BASE_URL=http://localhost:4000
