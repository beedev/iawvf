# IAW VDF (Node) — environment template. Copy to .env and fill in real values.
# .env is GITIGNORED. NEVER commit real secrets.

NODE_ENV=development
PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5433/iawnode?schema=public

# Auth — JWT signing secret. Generate a strong random value for each environment.
# Required at startup when NODE_ENV=production.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h

# CORS — comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:5173

# OpenAI integration
OPENAI_ENABLED=false
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4.1
OPENAI_BASE_URL=https://api.openai.com/v1
